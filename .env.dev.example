# Base de datos (apunta al contenedor dev interno)
DATABASE_URL=postgresql://tasas_user:tasas_password@db:5432/tasas_db_dev

# Redis (apunta al contenedor redis dev interno)
REDIS_URL=redis://redis:6379/0

# JWT y Seguridad
JWT_SECRET_KEY=cambiar_por_clave_dev_de_al_menos_32_caracteres
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# Configuración de la aplicación
APP_NAME=Tasas Project API (DEV)
APP_VERSION=1.0.0-dev
APP_ENV=development
DEBUG=true
LOG_LEVEL=DEBUG

# CORS
CORS_ORIGINS=http://localhost:3001,http://localhost:3000,http://localhost:8080

# Configuración de passwords
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_NUMBERS=true
PASSWORD_REQUIRE_SPECIAL=false
BCRYPT_ROUNDS=12

# Rate limiting
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=15

# Scraping
SCRAPING_INTERVAL_MINUTES=5
SCRAPING_ENABLED=true
SCRAPING_TIMEOUT_SECONDS=30
SCRAPING_MAX_RETRIES=3

# Root user dev
ROOT_USER_EMAIL=admin@dev.example.com
ROOT_USER_PASSWORD=dev_password_here
ROOT_USER_NAME=Admin Dev

# Bot notify (alertas de divergencia al WhatsApp del operador)
BOT_NOTIFY_URL=http://localhost:3457

# Actualización externa de tasas (script del operador, ej. BRL)
# Token compartido entre el script del operador y el backend. Generar con:
#   openssl rand -hex 32
# Debe ser EL MISMO valor en el .env del backend y en el run.sh del operador.
EXTERNAL_RATE_API_KEY=cambiar_por_un_token_aleatorio_largo

# Web Push (VAPID) — generar con: vapid --gen (py_vapid)
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
VAPID_CLAIMS_SUB=mailto:admin@example.com
